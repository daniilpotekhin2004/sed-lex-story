{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wizard-meta.schema.json",
  "title": "WizardMeta",
  "type": "object",
  "required": [
    "step",
    "mode",
    "status"
  ],
  "properties": {
    "step": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "draft",
        "final"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "warning",
        "error"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Issue"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Issue"
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string"
        },
        "tokens_in": {
          "type": "integer"
        },
        "tokens_out": {
          "type": "integer"
        },
        "latency_ms": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "trace_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "Issue": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "hint": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}