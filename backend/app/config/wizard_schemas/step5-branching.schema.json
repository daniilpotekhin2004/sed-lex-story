{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "step5-branching.schema.json",
  "title": "WizardStep5Response",
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "branches"
      ],
      "properties": {
        "branches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "choice_key",
              "choice_prompt",
              "options"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "scene_id": {
                "type": "string"
              },
              "choice_key": {
                "type": "string"
              },
              "choice_prompt": {
                "type": "string"
              },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "label",
                    "summary",
                    "is_mainline"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "label": {
                      "type": "string"
                    },
                    "summary": {
                      "type": "string"
                    },
                    "is_mainline": {
                      "type": "boolean"
                    },
                    "next_scenes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "notes": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "$ref": "wizard-meta.schema.json"
    }
  },
  "additionalProperties": false
}