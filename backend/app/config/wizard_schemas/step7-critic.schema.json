{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "step7-critic.schema.json",
  "title": "WizardStep7Response",
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "overall_summary",
        "verdict",
        "continuity_score",
        "checks",
        "issues"
      ],
      "properties": {
        "overall_summary": {
          "type": "string"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "revise"
          ]
        },
        "continuity_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "status",
              "note"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "warn",
                  "fail"
                ]
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "severity",
              "title",
              "description",
              "recommendation",
              "blocking",
              "resolved"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              },
              "affected_steps": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "affected_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "evidence": {
                "type": "string"
              },
              "blocking": {
                "type": "boolean"
              },
              "resolved": {
                "type": "boolean"
              },
              "resolution_note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "$ref": "wizard-meta.schema.json"
    }
  },
  "additionalProperties": false
}
