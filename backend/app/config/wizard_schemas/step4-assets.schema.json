{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "step4-assets.schema.json",
  "title": "WizardStep4Response",
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "assets"
      ],
      "properties": {
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "type",
              "source_id",
              "action",
              "priority",
              "status"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "character",
                  "location"
                ]
              },
              "source_id": {
                "type": "string"
              },
              "action": {
                "type": "string",
                "enum": [
                  "create",
                  "update",
                  "skip"
                ]
              },
              "priority": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "dependencies": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "draft",
                  "approved",
                  "rejected"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "$ref": "wizard-meta.schema.json"
    }
  },
  "additionalProperties": false
}